.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
# Ignore .claude/ session/cache state, but keep .claude/skills/ which is a
# tracked part of the repo (otherwise a contributor running
# `git rm -r --cached .claude/` to fix a local edit would silently delete
# the skill definitions). Order matters — exclusion has to come after the
# blanket ignore. Use `.claude/*` (contents) rather than `.claude/` (the
# directory): git cannot re-include a path whose parent *directory* is
# excluded, so `!.claude/skills/` only works when the dir itself isn't ignored.
.claude/*
!.claude/skills/
!.claude/skills/**

# Python bytecode
__pycache__/
*.pyc

# Secrets - never commit these!
secrets/
*.secret
*.key

# Private per-user workspaces (chart values + secrets for workspaces that
# don't need to be exposed in the public repo). Each subdir mirrors the
# `deployments/<user>/` + `secrets/<user>/` shape but everything stays out
# of git. See docs/NEW_USER_PROVISIONING.md → "Private workspaces".
users-private/

# Local checkout of the GitOps workspace-config repo (provision.gitops.repo),
# synced via `make users-sync`. The single source of truth for provisioned
# workspaces; `make deploy/ship USER=<u>` resolves config from here too.
.users/

# Ad-hoc patches / diffs produced by `git format-patch` or `git diff` for
# local review. These shouldn't be committed; the canonical change-history
# lives in `git log`.
*.patch
*.diff

# Playwright MCP server session artifacts (console logs + page snapshots
# auto-written when browser tools run from this directory). Useful as
# flight-recorder data during a session, regenerable, not source.
.playwright-mcp/
# Coverage reports
charts/workspace/.coverage
charts/workspace/htmlcov/
charts/workspace/web/coverage/
*.coverage
.coverage
.coverage.*
