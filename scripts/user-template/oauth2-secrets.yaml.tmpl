# OAuth2 client secret for __USER__'s workspace.
# This file overrides oauth2.clientSecret from values.yaml at deploy time.
#
# Get the secret from:
#   https://github.com/settings/developers → your OAuth App → Generate a new client secret
#
# Lifetime: GitHub-issued client secrets don't expire by default. If you
# rotate it, just edit this file and `make deploy USER=__USER__`.
oauth2:
  clientSecret: "CHANGE ME"   # CHANGE ME — paste raw secret from GitHub
