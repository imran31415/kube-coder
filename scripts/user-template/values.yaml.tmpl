# Workspace values for __USER__ — generated by scripts/new-user.sh on __DATE__.
# Stored at users-private/__USER__/values.yaml (gitignored).
#
# Fields you MUST change before `make deploy USER=__USER__`:
#   - user.host             (set to a hostname whose DNS already points
#                            at the cluster's nginx ingress IP)
#   - user.env GIT_USER_NAME / GIT_USER_EMAIL
#   - oauth2.githubUsers    (comma-separated allowlist of GitHub logins)
#   - oauth2.clientId       (from your GitHub OAuth app)
#   - oauth2.clientSecret   (from your GitHub OAuth app, in secrets/oauth2.yaml)
#
# Run `make validate-user USER=__USER__` to verify these are set before
# attempting a deploy.

namespace: coder

user:
  name: __USER__
  pvcSize: 50Gi
  host: __USER__.dev.scalebase.io   # CHANGE ME — must resolve to ingress IP
  env:
    - name: GIT_USER_NAME
      value: "CHANGE ME"            # CHANGE ME — e.g. "Chase Smith"
    - name: GIT_USER_EMAIL
      value: "CHANGE ME"            # CHANGE ME — e.g. "chase@example.com"

image:
  repository: registry.digitalocean.com/resourceloop/coder
  tag: devlaptop-__IMAGE_TAG__
  pullPolicy: Always
  pullSecretName: regcred

ingress:
  className: nginx
  auth:
    type: oauth2
    secretName: api-basic-auth
  tls:
    enabled: true
    secretName: __USER__-dev-scalebase-io-tls
    clusterIssuer: letsencrypt-production

# OAuth2 — cookieSecret is pre-generated for this workspace.
# clientId + clientSecret come from a GitHub OAuth app for THIS host:
#
#   1. Go to https://github.com/settings/developers → New OAuth App
#   2. Homepage:  https://__USER__.dev.scalebase.io
#   3. Callback:  https://__USER__.dev.scalebase.io/oauth2/callback
#   4. Copy the Client ID into oauth2.clientId below.
#   5. Generate a client secret and put it in
#      users-private/__USER__/secrets/oauth2.yaml (keeps the real secret
#      out of this committed-shaped file even though users-private/ is
#      already gitignored — defense in depth).
oauth2:
  githubUsers: "CHANGE ME"          # CHANGE ME — e.g. "chase31415,collab-user"
  cookieSecret: "__COOKIE_SECRET__"
  clientId:     "CHANGE ME"         # CHANGE ME — Iv1.xxxxxxxxxxxxxxxx
  clientSecret: "OVERRIDE-IN-SECRETS-OAUTH2-YAML"

resources:
  requests:
    cpu: "1"
    memory: 2Gi
  limits:
    cpu: "2"
    memory: 4Gi

build:
  mode: buildkit
  kanikoImage: gcr.io/kaniko-project/executor:latest
  pushSecretName: regcred
  defaultDestinationRepo: registry.digitalocean.com/resourceloop/coder

ssh:
  enabled: false
  port: 22

# Claude Code auth:
#   - OAuth/subscription: leave apiKey blank; run `make shell USER=__USER__`
#     then `claude` once to interactively log in.
#   - API key (pay-per-use): drop it in users-private/__USER__/secrets/claude.yaml.
claude:
  apiKey: ""

# GitHub App for repo access:
#   Drop credentials in users-private/__USER__/secrets/github-app.yaml.
github:
  app:
    appId: ""
    installationId: ""
    privateKey: ""
