{
  "name": "kube-coder-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@preact/signals": "1.3.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "dompurify": "^3.4.3",
    "marked": "^18.0.3",
    "preact": "10.24.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.9.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/preact": "3.2.4",
    "@testing-library/user-event": "14.5.2",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/node": "22.10.1",
    "@vitest/coverage-v8": "^2.1.4",
    "happy-dom": "20.8.9",
    "playwright": "^1.60.0",
    "playwright-core": "1.50.0",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
