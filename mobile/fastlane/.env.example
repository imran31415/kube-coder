# fastlane credentials for `deliver` (App Store metadata + screenshots).
#
# Copy to `fastlane/.env` (git-ignored) and fill in. NONE of these values may
# be committed — this is an open-source repo. fastlane auto-loads fastlane/.env.

# --- Preferred: App Store Connect API key (no Apple ID password, no 2FA) ---
# Create one at App Store Connect → Users and Access → Integrations → App Store
# Connect API. Download the .p8 once and store it outside the repo.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# --- Alternative: Apple ID login (used only if no API key above) ---
# FASTLANE_APPLE_ID=you@example.com
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# ASC_TEAM_ID=123456789          # only if the Apple ID is on multiple ASC teams
# APPLE_TEAM_ID=ABCDE12345       # developer portal team id, if multiple

# Override the app record deliver targets (defaults to app.kubecoder.mobile).
# FL_APP_IDENTIFIER=app.kubecoder.mobile

# Set FL_FORCE=true to skip the interactive confirmation locally (CI does this
# automatically via CI=true).
# FL_FORCE=true

# --- Android / Google Play (fastlane supply) ---
# Play Console service-account JSON (Setup → API access). Defaults to
# mobile/play-service-account.json — the same file eas.json's submit config
# uses — so you only need this if it lives elsewhere.
# SUPPLY_JSON_KEY=/absolute/path/to/play-service-account.json
# SUPPLY_PACKAGE_NAME=app.kubecoder.mobile