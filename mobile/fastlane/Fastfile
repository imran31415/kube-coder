# fastlane Fastfile — App Store *listing* automation for the kube-coder mobile
# app. Builds and binary uploads are EAS's job (see the mobile-build* /
# mobile-submit-ios Makefile targets); these lanes only push the store
# metadata and screenshots via `deliver`.
#
# Usage (from the repo root):
#   make mobile-metadata            # push text + screenshots
#   make mobile-metadata-download   # pull the live listing back into metadata/
# or directly:
#   cd mobile && bundle exec fastlane ios metadata

default_platform(:ios)

# Repo root is two levels up from this file (mobile/fastlane/Fastfile).
REPO_ROOT = File.expand_path("../..", __dir__)

# iOS App Store screenshots are pushed by scripts/sync-ios-screenshots.rb, not
# by deliver (see the ios platform block below for why). The source-of-truth
# PNGs live under ios-assets/<device-class>/ (regenerated by
# `make mobile-screenshots`).

# supply reads Play screenshots from metadata/android/<locale>/images/<type>/.
# We keep the source PNGs single-sourced under android-assets/ and copy them
# into the (git-ignored) images/ folders at run time, mapping each device class
# to the Play screenshot type.
def stage_android_screenshots
  require "fileutils"
  src_root = File.join(REPO_ROOT, "android-assets")
  images = File.join(__dir__, "metadata", "android", "en-US", "images")
  mapping = { "phone" => "phoneScreenshots", "tablet-10" => "tenInchScreenshots" }
  count = 0
  mapping.each do |cls, play_type|
    dst = File.join(images, play_type)
    FileUtils.rm_rf(dst)
    FileUtils.mkdir_p(dst)
    Dir.glob(File.join(src_root, cls, "*.png")).sort.each do |png|
      FileUtils.cp(png, File.join(dst, File.basename(png)))
      count += 1
    end
  end
  UI.user_error!("No screenshots found under android-assets/ — run `make mobile-screenshots` first") if count.zero?
  UI.message("Staged #{count} Play screenshots into metadata/android/en-US/images/")
end

# Authenticate with an App Store Connect API key when one is configured (the
# recommended, 2FA-free path). If these env vars are absent, deliver falls back
# to Apple ID login (FASTLANE_APPLE_ID + an app-specific password / session).
before_all do
  if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_PATH"]
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false,
    )
    UI.message("Using App Store Connect API key #{ENV['ASC_KEY_ID']}")
  end
end

platform :ios do
  # Screenshots are deliberately NOT pushed through deliver: deliver runs a
  # second verification pass that re-uploads already-present images, leaving
  # duplicates (7 wanted → capped at 10 with dupes). Screenshots are synced
  # deterministically by scripts/sync-ios-screenshots.rb (delete-then-upload,
  # single pass) via `make mobile-ios-screenshots`. These lanes push listing
  # TEXT only.
  # force: true skips deliver's interactive HTML-preview confirmation. These
  # lanes run non-interactively (make target / CI, no TTY), where the prompt
  # crashes with "Could not retrieve response as fastlane runs in non-interactive
  # mode". The preview only re-renders the metadata/ files we're pushing, so
  # skipping the confirmation is safe.
  desc "Push App Store listing text to App Store Connect (no screenshots, no binary)"
  lane :metadata do
    deliver(skip_screenshots: true, force: true)
  end

  desc "Alias of `metadata` — listing text only (name, description, keywords, …)"
  lane :metadata_text do
    deliver(skip_screenshots: true, force: true)
  end
end

# --- Android / Google Play (supply) -----------------------------------------
# Same division of labour: EAS builds & uploads the .aab (`make mobile-build-
# android` / `eas submit`). supply only syncs the Play store listing text +
# screenshots. Auth is a Play service-account JSON — path from SUPPLY_JSON_KEY,
# defaulting to mobile/play-service-account.json (the same file eas.json's
# submit config references). That file is a secret and is git-ignored.
PLAY_PKG = ENV["SUPPLY_PACKAGE_NAME"] || "app.kubecoder.mobile"
PLAY_KEY = ENV["SUPPLY_JSON_KEY"] || File.join(REPO_ROOT, "mobile", "play-service-account.json")

platform :android do
  desc "Push Play Store listing text + screenshots to Google Play (no binary)"
  lane :metadata do
    stage_android_screenshots
    supply(
      package_name: PLAY_PKG,
      json_key: PLAY_KEY,
      skip_upload_apk: true,
      skip_upload_aab: true,
      # Changelogs are tied to a release/track; a listing-only push doesn't need
      # one. The .aab (and its release notes) go up via EAS submit.
      skip_upload_changelogs: true,
    )
  end

  desc "Push only the Play listing text (title, descriptions) — no screenshots"
  lane :metadata_text do
    supply(
      package_name: PLAY_PKG,
      json_key: PLAY_KEY,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
    )
  end
end
